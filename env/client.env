# uftp-fpv-client 環境変数
# このファイルを /etc/uftp-fpv/client.env に配置してください

# --- 送信先 ---
UFTP_SERVER=136.110.67.111

# receiverのUID（必須）
# 求め方: printf '0x%02X%02X%02X%02X\n' $(echo <GCE内部IP> | tr '.' ' ')
UFTP_RECEIVER_ID=0x0A920002

# 送信側UIDを固定（推奨）
# 求め方: printf '0x%02X%02X%02X%02X\n' $(hostname -I | awk '{print $1}' | tr '.' ' ')
UFTP_SENDER_ID=0xC0A8010A

# --- カメラ ---
CAMERA_INDEX=0
FPS=2
JPEG_QUALITY=80
# CAPTURE_WIDTH=1280
# CAPTURE_HEIGHT=720

# --- 転送 ---
# 転送レート上限 (Kbps) — イリジウムは15Kbps前後、プロトコル分を引いて少し余裕を持たせる
UFTP_RATE=12
# 応答待ち時間 (秒) — イリジウムのRTTは2〜5秒のため余裕を持たせる
UFTP_RESPONSE_WAIT=8.0
# subprocessタイムアウト (秒) — 転送時間+待ち時間を超えないよう設定
UFTP_TIMEOUT=120
# UFTP_OPTS=       # 追加のUFTPオプション
